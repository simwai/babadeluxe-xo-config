{
  "name": "@babadeluxe/xo-config",
  "version": "0.1.20",
  "description": "Shared XO ESLint configuration with Prettier integration",
  "author": "simwai",
  "type": "module",
  "keywords": [
    "eslint",
    "xo",
    "config",
    "typescript",
    "prettier"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "node": "./dist/index.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "npx rimraf -g ./dist/**/* && tsc",
    "test-package": "npm pack --dry-run",
    "publish-patch": "npm run build && npm version patch && npm publish",
    "publish-minor": "npm run build && npm version minor && npm publish",
    "publish-major": "npm run build && npm version major && npm publish"
  },
  "peerDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.43.0",
    "@typescript-eslint/parser": "^8.43.0",
    "xo": "^1.2.2"
  },
  "devDependencies": {
    "@sindresorhus/tsconfig": "^8.0.1",
    "rimraf": "^6.0.1",
    "typescript": "^5.9.2"
  }
}
