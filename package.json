{
  "name": "@babadeluxe/xo-config",
  "version": "0.1.26",
  "description": "Shared XO ESLint configuration with Prettier integration",
  "author": "simwai",
  "license": "UNLICENSED",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "eslint",
    "xo",
    "config",
    "typescript",
    "prettier"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "format": "xo --config ./src/index.ts --prettier",
    "build": "unbuild",
    "dev": "unbuild --stub",
    "prepack": "unbuild",
    "test-package": "npm pack --dry-run",
    "publish-patch": "npm version patch && npm publish",
    "publish-minor": "npm version minor && npm publish",
    "publish-major": "npm version major && npm publish",
    "prepare": "husky"
  },
  "peerDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.43.0",
    "@typescript-eslint/parser": "^8.43.0",
    "xo": "^1.2.2"
  },
  "devDependencies": {
    "@sindresorhus/tsconfig": "^8.0.1",
    "husky": "^9.1.7",
    "rimraf": "^6.0.1",
    "typescript": "^5.9.2",
    "unbuild": "^2.0.0"
  }
}
