#!/bin/bash
set -euo pipefail

staged_list="$(mktemp)"
trap 'rm -f "$staged_list"' EXIT

# Capture staged file paths as null-delimited stream to handle spaces in filenames
git diff --cached --name-only --diff-filter=ACM -z > "$staged_list"

if [[ ! -s "$staged_list" ]]; then
  echo "[pre-commit] no staged files found, skipping"
  exit 0
fi

echo "[pre-commit] running format..."
pnpm format || { echo "[pre-commit] ABORT: format failed"; exit 1; }
echo "[pre-commit] format passed"

# Re-stage originally staged files — guard against files deleted during auto-fix
echo "[pre-commit] re-staging auto-fixed files..."
while IFS= read -r -d '' file; do
  [[ -f "$file" ]] && git add "$file"
done < "$staged_list"

echo "[pre-commit] all checks passed"
