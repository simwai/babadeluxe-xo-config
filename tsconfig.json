{
  "extends": "@sindresorhus/tsconfig",
  "compilerOptions": {
    "outDir": "./dist",
    "sourceRoot": ".",
    "sourceMap": true,
    "experimentalDecorators": true,
    "erasableSyntaxOnly": false,
    "strict": true,
    "incremental": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "noEmit": false,
    "noErrorTruncation": true,
    "resolveJsonModule": true
  },
  "include": [
    "*.ts"
  ]
}